# PostgreSQL settings used by docker-compose
POSTGRES_DB=order_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Published service ports
ORDER_SERVICE_PORT=8001
INVENTORY_SERVICE_PORT=8002
PAYMENT_SERVICE_PORT=8003
SHIPMENT_SERVICE_PORT=8004
DISPATCHER_SERVICE_PORT=8005

# Simple startup retry settings used by the Python services
DATABASE_WAIT_TIMEOUT_SECONDS=30
DATABASE_WAIT_INTERVAL_SECONDS=1

# Dispatcher configuration
INVENTORY_SERVICE_URL=http://inventory-service:8002
PAYMENT_SERVICE_URL=http://payment-service:8003
SHIPMENT_SERVICE_URL=http://shipment-service:8004
POLL_INTERVAL_SECONDS=5
BATCH_SIZE=10
